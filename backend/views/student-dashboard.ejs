<!DOCTYPE html>
<html>
<head>
  <title>Student Dashboard</title>
  <style>
    body {
      margin: 0;
      font-family: Segoe UI, sans-serif;
      background: linear-gradient(135deg, #1e3c72, #2a5298);
      color: #fff;
    }

    .container {
      max-width: 900px;
      margin: 50px auto;
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(15px);
      padding: 40px;
      border-radius: 18px;
      box-shadow: 0 25px 60px rgba(0,0,0,0.4);
    }

    h2 {
      text-align: center;
      margin-bottom: 25px;
    }

    select, textarea {
      width: 100%;
      padding: 12px;
      border-radius: 8px;
      border: none;
      margin-bottom: 15px;
    }

    textarea {
      height: 100px;
      resize: none;
    }

    button {
      width: 100%;
      padding: 12px;
      border-radius: 8px;
      border: none;
      background: linear-gradient(45deg, #00c6ff, #0072ff);
      font-weight: bold;
      cursor: pointer;
      margin-bottom: 30px;
    }

    .complaint-card {
      background: rgba(255,255,255,0.12);
      padding: 20px;
      border-radius: 12px;
      margin-bottom: 20px;
    }

    .status {
      font-weight: bold;
      margin-top: 10px;
    }

    .pending { color: orange; }
    .progress { color: yellow; }
    .resolved { color: lightgreen; }

  </style>
</head>

<body>
  <div class="container">
    <h2>Submit Complaint</h2>

    <form method="POST" action="/student/submit-complaint">
      <select name="department" required>
        <option value="">Select Department</option>
        <option value="Hostel">Hostel</option>
        <option value="Library">Library</option>
        <option value="Exam">Exam Cell</option>
        <option value="Accounts">Accounts</option>
      </select>

      <textarea name="message" placeholder="Describe your issue..." required></textarea>

      <button type="submit">Submit Complaint</button>
    </form>

    <h2>Your Complaints</h2>

    <% if (complaints.length === 0) { %>
      <p>No complaints submitted yet.</p>
    <% } %>

    <% complaints.forEach(c => { %>
      <div class="complaint-card">
        <p><strong>Department:</strong> <%= c.department %></p>
        <p><strong>Message:</strong> <%= c.message %></p>



        <% if (c.status === "Pending") { %>
          <p class="status pending">Status: Pending</p>
        <% } else if (c.status === "In Progress") { %>
          <p class="status progress">Status: In Progress</p>
        <% } else { %>
            <p><strong>Remarks:</strong> <%= c.remarks %></p>
            <p>
              <a href="/uploads/<%= c.proofDocument %>" 
                target="_blank" style="color:lightgreen;">
                View Proof Document
              </a>
            </p>
          <% } %>
      </div>
    <% }) %>

  </div>
</body>
</html>